# ══════════════════════════════════════════════════════════════════════════════
#  Inkquire — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to version control.
#  See the Deployment Guide (Phase 23) for per-service setup instructions.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
#  Found at: supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Stripe (Platform Keys) ────────────────────────────────────────────────────
#  Found at: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Product Price IDs
#  Create products in the Stripe Dashboard first, then paste the price IDs here.
#  Pro Plan:    £19/month
#  Studio Plan: £49/month
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_STUDIO_MONTHLY=price_...

# Stripe Connect (for artist payouts — Destination Charges model)
#  Found at: dashboard.stripe.com → Connect → Settings → Client ID
STRIPE_CONNECT_CLIENT_ID=ca_...

# ── Google Gemini (AI Site Generation) ───────────────────────────────────────
#  Create at: https://aistudio.google.com/apikey
#  A valid key starts with "AIza" and is ~39 characters. Values that start with
#  anything else (e.g. "AQ.Ab8...") are NOT Gemini API keys and will be rejected.
GEMINI_API_KEY=AIza-your-key-here
#  Optional: override the model. If unset, a built-in fallback chain is tried
#  (gemini-2.0-flash → 2.5-flash → flash-latest → 1.5-flash).
# GEMINI_MODEL=gemini-2.0-flash

# ── Resend (Transactional Email) ──────────────────────────────────────────────
#  Found at: resend.com → API Keys
#  Domain must be verified before RESEND_FROM_EMAIL will work in production.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@inkdesk.live

# ── Upstash Redis (Rate Limiting) ─────────────────────────────────────────────
#  Found at: console.upstash.com → Your Database → REST API
UPSTASH_REDIS_REST_URL=https://your-database-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Google Maps (Studio location) — OPTIONAL ─────────────────────────────────
#  Found at: console.cloud.google.com → APIs & Services → Credentials
#  Enable the "Maps Static API" and "Places API" for this key.
#  If absent, the studio map section is hidden and the location picker in
#  Dashboard → Settings → Studio falls back to a plain text address field.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Sentry (Error Monitoring) — OPTIONAL ─────────────────────────────────────
#  Inkquire boots and runs normally without these values.
#  Safe to leave blank in local development.
#  Found at: sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=inkdesk
SENTRY_AUTH_TOKEN=your-sentry-auth-token-for-source-maps

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Inkquire

# Cron job authentication secret.
# Must be at least 32 characters. Used to authenticate POST requests to /api/cron/*.
# Generate a secure value with: openssl rand -hex 32
CRON_SECRET=replace-with-openssl-rand-hex-32-output
